{
  "name": "spec-cat",
  "version": "0.1.9",
  "description": "Spec-driven development workbench",
  "license": "MIT",
  "keywords": [
    "spec",
    "workflow",
    "nuxt",
    "git",
    "ai"
  ],
  "type": "module",
  "bin": {
    "spec-cat": "./bin/spec-cat.js"
  },
  "files": [
    "bin",
    ".output"
  ],
  "publishConfig": {
    "access": "public"
  },
  "engines": {
    "node": ">=20.0.0"
  },
  "scripts": {
    "build": "nuxt build",
    "dev": "nuxt dev",
    "generate": "nuxt generate",
    "preview": "nuxt preview",
    "prepack": "pnpm build",
    "pack:check": "pnpm pack",
    "typecheck": "nuxt typecheck",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage"
  },
  "dependencies": {
    "nuxt": "^3.16.0",
    "@xenova/transformers": "^2.17.2",
    "@heroicons/vue": "^2.2.0",
    "better-sqlite3": "^12.6.2",
    "chokidar": "^5.0.0",
    "dayjs": "^1.11.13",
    "dompurify": "^3.2.0",
    "marked": "^15.0.12",
    "sharp": "^0.32.6",
    "shiki": "^3.22.0",
    "sqlite-vec": "^0.1.6-alpha.2",
    "ws": "^8.19.0",
    "yaml": "^2.8.2"
  },
  "devDependencies": {
    "@nuxt/devtools": "^2.0.0",
    "@nuxt/test-utils": "^3.23.0",
    "@nuxtjs/tailwindcss": "^6.12.0",
    "@pinia/nuxt": "^0.5.5",
    "@types/dompurify": "^3.2.0",
    "@types/node": "^22.0.0",
    "@types/better-sqlite3": "^7.6.13",
    "@types/ws": "^8.18.1",
    "@vitejs/plugin-vue": "^6.0.3",
    "@vue/test-utils": "^2.4.6",
    "happy-dom": "^20.4.0",
    "jsdom": "^27.4.0",
    "pinia": "^2.2.0",
    "tailwindcss": "^3.4.0",
    "typescript": "^5.6.0",
    "unplugin-auto-import": "^21.0.0",
    "vitest": "^4.0.18",
    "vue": "^3.5.0",
    "vue-router": "^4.4.0",
    "vue-tsc": "^2.2.0"
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "better-sqlite3",
      "sharp"
    ]
  }
}
